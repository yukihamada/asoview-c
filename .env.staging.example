# asoview-c ステージング環境変数
# cp .env.staging.example .env.staging && vi .env.staging
#
# 重要: ステージングは本番と別シークレットを使用すること

# ─── サーバー ──────────────────────────────────────────────────────────────
PORT=3001
DATABASE_URL=/data/asoview-staging.db
FRONTEND_URL=http://localhost:3010
CORS_ORIGIN=http://localhost:3010

# ─── セキュリティ（ステージング用 — 本番とは異なる値を使うこと）─────────
# openssl rand -hex 32
JWT_SECRET=staging-jwt-secret-change-me-to-random-64-chars

# JWT ローテーション: 旧シークレット（ゼロダウンタイムで新 JWT_SECRET に移行する際に設定）
# JWT_SECRET_PREV=old-jwt-secret-here

# openssl rand -hex 16
ADMIN_KEY=staging-admin-key-change-me

# ─── Stripe テストキー ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── メール（Resend — ステージング用送信元） ──────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM=staging@yourdomain.com

# ─── S3（任意） ────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=your-staging-bucket
# AWS_S3_REGION=ap-northeast-1
