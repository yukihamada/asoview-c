# asoview-c 環境変数設定例
# cp .env.example .env && vi .env

# ─── サーバー ─────────────────────────────────────────────────────────────
PORT=3001

# SQLite（デフォルト）
DATABASE_URL=asoview.db
# PostgreSQL の場合:
# DATABASE_URL=postgres://user:pass@localhost:5432/asoview
# MySQL の場合:
# DATABASE_URL=mysql://user:pass@localhost:3306/asoview

# ─── セキュリティ（本番環境では必ず変更すること）────────────────────────
# openssl rand -hex 32 で生成した 64 文字のランダム文字列を設定する
JWT_SECRET=change-me-to-a-random-32-char-minimum-secret

# openssl rand -hex 16 で生成した管理キー
ADMIN_KEY=change-me-to-a-secure-admin-key

# CORS（本番環境では必ず自ドメインを設定すること。未設定では * でワーニングが出る）
CORS_ORIGIN=https://yourdomain.com

# ─── Stripe（任意 — 未設定時は即時 confirmed に fallback）───────────────
# Stripe ダッシュボード → 開発者 → APIキー
STRIPE_SECRET_KEY=sk_test_...

# Stripe ダッシュボード → 開発者 → Webhook → エンドポイント → 署名シークレット
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── メール（任意 — Resend.com）────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM=info@yourdomain.com

# パスワードリセットメール内のリンクに使用
FRONTEND_URL=https://yourdomain.com

# ─── S3 画像アップロード（任意）────────────────────────────────────────
# /api/v1/admin/upload-url エンドポイントで使用
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=ap-northeast-1

# ─── MySQL バックエンド（make DB=mysql ビルド時のみ）───────────────────
# DATABASE_URL=mysql://... が設定されていればこれらは不要
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=asoview
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=asoview
