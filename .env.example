# ────────────────────────────────────────────────────
# asoview-c 環境変数サンプル
# cp .env.example .env && vi .env
# ────────────────────────────────────────────────────

# ── 必須 ──────────────────────────────────────────
# JWTトークン署名キー（32バイト以上のランダム文字列）
JWT_SECRET=changeme-use-openssl-rand-hex-32

# 管理者APIキー
ADMIN_KEY=changeme-use-openssl-rand-hex-24

# データベースパス（省略時: ./asoview.db）
DATABASE_URL=/data/asoview.db

# サーバーポート（省略時: 3001）
PORT=3001

# ── メール送信 (Resend) ────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=noreply@yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── Stripe 決済 ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Google OAuth（任意）────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# ── 管理者 TOTP 2FA（任意・推奨）─────────────────
# セットアップ: curl -H "X-Admin-Key: $ADMIN_KEY" http://localhost:3001/api/v1/admin/2fa/setup
# → 返ってきた totp_secret を設定して再起動
# ADMIN_TOTP_SECRET=JBSWY3DPEHPK3PXP

# ── S3 互換ストレージ（プラン画像アップロード用）──
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# S3_BUCKET=your-bucket
# S3_REGION=ap-northeast-1
